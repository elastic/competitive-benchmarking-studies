# ── Engine versions ───────────────────────────────────────────────────────────
# ES 9.5.0-SNAPSHOT requires: docker login docker.elastic.co
# For public use without Elastic account: change to 9.4.3 (no synthetic source)
ES_VERSION=9.5.0-SNAPSHOT
PROMETHEUS_VERSION=3.12.0
MIMIR_VERSION=3.1.0

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ES_HEAP=4g

# ── metricsgenreceiver ────────────────────────────────────────────────────────
SCALE=100             # number of simulated hosts
INTERVAL=1s           # metric emission interval
START_NOW_MINUS=270m  # data window (270m = low-cardinality team setup)
