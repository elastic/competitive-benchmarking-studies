# ── Benchmark ─────────────────────────────────────────────────────────────────
RUN_ID=es-9.4-vs-qd-1.18-jingra-0.2.3
DATASET_DATA_URL=https://storage.googleapis.com/elastic-benchmark-datasets/wiki-dpr-e5-768/data.parquet
DATASET_QUERIES_URL=https://storage.googleapis.com/elastic-benchmark-datasets/wiki-dpr-e5-768/queries.parquet
JINGRA_IMAGE=sachinfrayneelastic/jingra:0.2.3

# ── Engine Versions ───────────────────────────────────────────────────────────
ELASTICSEARCH_VERSION=9.4.1
QDRANT_VERSION=1.18.1

# ── Kubernetes cluster ────────────────────────────────────────────────────────
STORAGE_CLASS_NAME=hyperdisk-balanced-rwo
STORAGE_SIZE=200Gi
WORKER_COUNT=3
MEMORY_REQUEST=26Gi
MEMORY_LIMIT=26Gi
CPU_REQUEST=7
CPU_LIMIT=7

# ── GKE cluster ───────────────────────────────────────────────────────────────
GKE_ZONE_DEFAULT=us-central1-a
DELETION_PROTECTION=false

# ── GKE node pools ────────────────────────────────────────────────────────────
MAIN_POOL_MACHINE_TYPE=n4-standard-8
MAIN_POOL_NODE_COUNT=3
MAIN_POOL_DISK_SIZE_GB=100
MAIN_POOL_DISK_TYPE=hyperdisk-balanced

JINGRA_POOL_NAME=jingra-nodepool
JINGRA_POOL_MACHINE_TYPE=e2-standard-8
JINGRA_POOL_NODE_COUNT=1
JINGRA_POOL_DISK_SIZE_GB=50

UI_POOL_MACHINE_TYPE=e2-standard-2
UI_POOL_NODE_COUNT=1
UI_POOL_DISK_SIZE_GB=50
