# ── GCP ───────────────────────────────────────────────────────────────────────
PROJECT_ID=your-gcp-project-id
GOOGLE_CREDENTIALS='{"type":"service_account","project_id":"..."}'

# ── Docker registry ───────────────────────────────────────────────────────────
DOCKER_EMAIL=your-email@example.com
DOCKER_PASSWORD=your-password
DOCKER_REGISTRY=your-docker-registry
DOCKER_USERNAME=your-username

# ── Jingra ────────────────────────────────────────────────────────────────────
JINGRA_IMAGE=your-registry.example.com/your-namespace/jingra:0.2.2

# ── Results cluster ───────────────────────────────────────────────────────────
RESULTS_ES_PASSWORD=your-results-cluster-password
RESULTS_ES_URL=https://your-cluster.es.io
RESULTS_ES_USER=elastic