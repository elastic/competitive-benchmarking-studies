# ── Python ────────────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1

# ── Engine versions ───────────────────────────────────────────────────────────
ES_VERSION=9.4.2
PROMETHEUS_VERSION=3.12.0
MIMIR_VERSION=3.1.0

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ES_HEAP=6g  # should be set to (CONTAINER_MEMORY_LIMIT / 2)

# ── Resource limits (applied to elasticsearch, prometheus, mimir containers) ───
CONTAINER_MEMORY_LIMIT=12g
CONTAINER_CPU_LIMIT=12

# ── Binary versions ───────────────────────────────────────────────────────────
METRICSGENRECEIVER_VERSION=1.0.7
VEGETA_VERSION=12.12.0

# ── metricsgenreceiver ────────────────────────────────────────────────────────
SCALE=100             # number of simulated hosts
INTERVAL=1s           # metric emission interval
START_NOW_MINUS=270m  # data window (270m = low-cardinality team setup)
