# ── Python ────────────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1

# ── Engine versions ───────────────────────────────────────────────────────────
ES_VERSION=9.4.2
PROMETHEUS_VERSION=3.12.0
MIMIR_VERSION=3.1.1

# ── Engine connection URLs (local docker compose ports) ────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
PROMETHEUS_URL=http://localhost:9090
MIMIR_URL=http://localhost:8080

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ES_HEAP=6g  # should be set to (CONTAINER_MEMORY_LIMIT / 2)
ES_DATA_STREAM=metrics-hostmetricsreceiver.otel-default

# ── Resource limits (applied to elasticsearch, prometheus, mimir containers) ───
CONTAINER_MEMORY_LIMIT=12g
CONTAINER_CPU_LIMIT=12

# ── Binary versions ───────────────────────────────────────────────────────────
METRICSGENRECEIVER_VERSION=1.0.7
VEGETA_VERSION=12.12.0

# Scenario parameters (scale, interval, start_now_minus, seed) live in
# benchmarks/*.yml — select one with `--benchmark <name>` (see benchmarks/loader.py).
