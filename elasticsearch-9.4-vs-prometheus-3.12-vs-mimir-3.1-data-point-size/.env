# ── Python ────────────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1

# ── Engine versions ───────────────────────────────────────────────────────────
ES_VERSION=9.4.2
PROMETHEUS_VERSION=3.12.0
MIMIR_VERSION=3.1.0

# ── Container resource limits ────────────────────────────────────────────────
# Applied to each engine container. Defaults (12 CPUs / 12g memory) assume a
# beefy host — lower these to fit what's actually available to Docker.
#CONTAINER_CPU_LIMIT=4
#CONTAINER_MEMORY_LIMIT=8g

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# ES_HEAP is derived automatically in the Makefile as 50% of
# CONTAINER_MEMORY_LIMIT — set it here only to override that.
#ES_HEAP=6g

# ── Binary versions ───────────────────────────────────────────────────────────
METRICSGENRECEIVER_VERSION=1.0.7
VEGETA_VERSION=12.12.0

# ── metricsgenreceiver ────────────────────────────────────────────────────────
SCALE=100             # number of simulated hosts
INTERVAL=1s           # metric emission interval
START_NOW_MINUS=270m  # data window (270m = low-cardinality team setup)
