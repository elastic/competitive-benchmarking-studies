receivers:
  metricsgen:
    seed: {{ seed }}
    start_now_minus: {{ start_now_minus }}
    interval: {{ interval }}
    real_time: false
    exit_after_end: true
    exit_after_end_timeout: 15s
    scenarios:
      - path: builtin/hostmetrics
        scale: {{ scale }}

processors:
  {% if engine in ("prometheus", "mimir") %}
  transform:
    metric_statements:
      - context: datapoint
        statements:
          - merge_maps(datapoint.attributes, resource.attributes, "insert")
  {% endif %}
  batch:

exporters:
  {% if debug %}
  nop:
  {% elif engine == "clickhouse" %}
  clickhouse:
    endpoint: {{ export_endpoint }}
    database: {{ clickhouse_database }}
    compress: lz4
    metrics_table_name: otel_metrics
    create_schema: false
    timeout: 10s
    sending_queue:
      enabled: true
      block_on_overflow: true
      num_consumers: 25
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 30s
      max_elapsed_time: 300s
  {% else %}
  otlphttp/{{ engine }}:
    endpoint: {{ export_endpoint }}
    {% if compression %}
    compression: gzip
    {% endif %}
    {% if engine == "mimir" %}
    headers:
      X-Scope-OrgID: mimirtest
    {% endif %}
    tls:
      insecure: true
    sending_queue:
      enabled: true
      block_on_overflow: true
      queue_size: 25
      num_consumers: 25
  {% endif %}

service:
  telemetry:
    metrics:
      level: none   # disable internal scrape endpoint to avoid port conflicts
  pipelines:
    metrics:
      receivers: [metricsgen]
      processors:
        {% if engine in ("prometheus", "mimir") %}
        - transform
        {% endif %}
        - batch
      exporters:
        {% if debug %}
        [nop]
        {% elif engine == "clickhouse" %}
        [clickhouse]
        {% else %}
        [otlphttp/{{ engine }}]
        {% endif %}
