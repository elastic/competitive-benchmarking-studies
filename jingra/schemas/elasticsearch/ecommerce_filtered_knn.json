{
  "name": "ecommerce_filtered_knn",
  "description": "Index mapping for filtered k-NN search with BBQ HNSW",
  "template": {
    "mappings": {
      "properties": {
        "search_catalog_embedding": {
          "type": "dense_vector",
          "element_type": "float",
          "dims": 128,
          "index": true,
          "similarity": "cosine",
          "index_options": {
            "type": "bbq_hnsw",
            "ef_construction": 100,
            "m": 16,
            "rescore_vector": {
              "oversample": 3.0
            }
          }
        },
        "valid": {
          "type": "boolean"
        }
      }
    },
    "settings": {
      "number_of_shards": "3",
      "number_of_replicas": "1"
    }
  }
}
